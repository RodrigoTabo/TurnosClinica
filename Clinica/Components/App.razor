@using Microsoft.AspNetCore.Components.Authorization
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    @* <-- nuevo css --> *@
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="@Assets["TurnosClinica.styles.css"]" />
    <link rel="stylesheet" href="css/admin-theme.css" />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;900&display=swap" />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />

    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes />
    </CascadingAuthenticationState>
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
<footer class="border-top bg-white px-3 px-md-4 py-5">
    <div class="container-fluid px-0" style="max-width: 1200px;">
        <div class="row g-4 g-md-5">
            <div class="col-12 col-md-3">
                <div class="d-flex align-items-center gap-2 text-primary mb-3">
                    <span class="material-symbols-outlined fs-4">medical_services</span>
                    <h2 class="h5 fw-bold mb-0 text-dark">MediCare Clinica</h2>
                </div>

                <p class="text-secondary small mb-0">
                    Ofrecemos servicios médicos de alta calidad con un enfoque centrado en el paciente. Tu bienestar comienza con nosotros.
                </p>
            </div>

            <div class="col-6 col-md-3">
                <h4 class="h6 fw-bold mb-3 text-dark">Enlaces rápidos</h4>
                <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                    <li><a class="text-secondary text-decoration-none" href="#">Buscar un doctor</a></li>
                    <li><a class="text-secondary text-decoration-none" href="#">Especialidades</a></li>
                    <li><a class="text-secondary text-decoration-none" href="#">Reserva en línea</a></li>
                    <li><a class="text-secondary text-decoration-none" href="#">Portal del paciente</a></li>
                </ul>
            </div>

            <div class="col-6 col-md-3">
                <h4 class="h6 fw-bold mb-3 text-dark">Soporte</h4>
                <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                    <li><a class="text-secondary text-decoration-none" href="#">FAQs</a></li>
                    <li><a class="text-secondary text-decoration-none" href="#">Política de privacidad</a></li>
                    <li><a class="text-secondary text-decoration-none" href="#">Condiciones de servicio</a></li>
                    <li><a class="text-secondary text-decoration-none" href="#">Contactar con soporte técnico</a></li>
                </ul>
            </div>

            <div class="col-12 col-md-3">
                <h4 class="h6 fw-bold mb-3 text-dark">Informacion</h4>
                <p class="text-secondary small mb-3">Manténgase actualizado con los últimos consejos de salud y noticias clínicas..</p>

                <div class="input-group">
                    <input type="email"
                           class="form-control"
                           placeholder="Ingrese su email..."
                         

                    <button class="btn btn-primary" type="button">
                        <span class="material-symbols-outlined" style="font-size: 18px;">send</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 mt-5 pt-4 border-top">
            <p class="text-secondary small mb-0">© 2026 MediCare Health Systems. Todos los derechos reservados.</p>

            <div class="d-flex gap-3">
                <a class="text-secondary text-decoration-none" href="#"><span class="material-symbols-outlined">public</span></a>
                <a class="text-secondary text-decoration-none" href="#"><span class="material-symbols-outlined">share</span></a>
                <a class="text-secondary text-decoration-none" href="#"><span class="material-symbols-outlined">mail</span></a>
            </div>
        </div>
    </div>
</footer>

</html>