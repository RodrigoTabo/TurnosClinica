@page "/registrarturno"
@rendermode InteractiveServer
@using TurnosClinica.Application.DTOs.Turnos
@using TurnosClinica.Application.Services.Turnos
@using TurnosClinica.Application.Services.Medicos
@using TurnosClinica.Application.Services.Consultorios
@inject ITurnosService TurnosService
@inject IMedicosService MedicosService
@inject IConsultorioService ConsultorioService
@inject NavigationManager Nav

<PageTitle>Turnos</PageTitle>


<main class="d-flex flex-column flex-grow-1 align-items-center">
    <div class="w-100 px-3 py-4" style="max-width: 1200px;">
        <button class="btn btn-outline-primary rounded-pill px-4 py-2 shadow-sm fw-semibold"
                @onclick="VolverAlInicio">
            ← Volver al inicio
        </button>
        <!-- Header -->
        <header class="mb-4">
            <h1 class="h2 fw-bold mb-1">Reservar cita</h1>
            <p class="text-secondary mb-0">Complete los datos a continuación para programar su visita.</p>
        </header>

        <div class="row g-4">
            <!-- Left column -->
            <div class="col-12 col-lg-8">
                <div class="d-flex flex-column gap-4">
                    <!-- Step 1 -->
                    <section class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold small"
                                      style="width: 32px; height: 32px;">1</span>
                                <h2 class="h5 fw-bold mb-0">Seleccioná un consultorio</h2>
                            </div>

                            <div class="d-flex gap-3 overflow-auto pb-2"
                                 style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
                                @foreach (var c in Consultorios)
                                {
                                    var seleccionado = Model.ConsultorioId == c.Id;

                                    <button type="button"
                                            class="btn p-0 text-start rounded-4 flex-shrink-0 overflow-hidden @(seleccionado
                                                                                                                                                                ? "border border-2 border-primary bg-primary bg-opacity-10"
                                                                                                                                                                : "border")"
                                            style="width: 320px; scroll-snap-align: start;"
                                            @onclick="() => SeleccionarConsultorio(c.Id)">
                                        <div class="d-flex align-items-center gap-3 p-3 w-100">
                                            <img src="https://www.its-salud.com/wp-content/uploads/2024/12/instituciones-salud-icon-1.png"
                                                 alt="@c.Institucion"
                                                 class="rounded-circle object-fit-cover flex-shrink-0"
                                                 style="width:64px;height:64px;" />

                                            <div class="min-w-0 flex-grow-1">
                                                <h4 class="h6 fw-bold mb-1 text-dark text-truncate">@c.Institucion</h4>
                                                <p class="small mb-0 text-primary"
                                                   style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                                    @c.Ciudad
                                                </p>
                                            </div>

                                            @if (seleccionado)
                                            {
                                                <span class="material-symbols-outlined text-primary flex-shrink-0">check_circle</span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>
                    </section>

                    <!-- Step 2 -->
                    <section class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold small"
                                      style="width: 32px; height: 32px;">2</span>
                                <h2 class="h5 fw-bold mb-0">Seleccioná un médico disponible</h2>
                            </div>

                            @if (Model.ConsultorioId == 0)
                            {
                                <div class="alert alert-light border mb-0">
                                    Elegí primero un consultorio para ver los médicos disponibles.
                                </div>
                            }
                            else if (CargandoMedicos)
                            {
                                <div class="alert alert-light border mb-0">
                                    Cargando médicos...
                                </div>
                            }
                            else if (!string.IsNullOrWhiteSpace(ErrorMedicos))
                            {
                                <div class="alert alert-danger mb-0">
                                    @ErrorMedicos
                                </div>
                            }
                            else if (Medicos.Count == 0)
                            {
                                <div class="alert alert-warning mb-0">
                                    No hay médicos disponibles para el consultorio seleccionado.
                                </div>
                            }
                            else
                            {
                                <div class="d-flex gap-3 overflow-auto pb-2"
                                     style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
                                    @foreach (var m in Medicos)
                                    {
                                        var seleccionado = Model.MedicoId == m.Id;

                                        <button type="button"
                                                class="btn p-0 text-start rounded-4 flex-shrink-0 @(seleccionado
                                                                                                                                                                                ? "border border-2 border-primary bg-primary bg-opacity-10"
                                                                                                                                                                                : "border")"
                                                style="width: 320px; scroll-snap-align: start;"
                                                @onclick="() => SeleccionarMedico(m.Id)">

                                            <div class="d-flex align-items-center gap-3 p-3">
                                                <img src="https://clipart-library.com/2024/cartoon-images-of-doctors/cartoon-images-of-doctors-0.png"
                                                     alt="@(m.Nombre + " " + m.Apellido)"
                                                     class="rounded-circle object-fit-cover flex-shrink-0"
                                                     style="width:64px;height:64px;" />

                                                <div class="min-w-0">
                                                    <h4 class="h6 fw-bold mb-1 text-dark text-truncate">@(m.Nombre + " " + m.Apellido)</h4>
                                                    <p class="small mb-0 text-primary text-truncate">@m.Especialidad</p>
                                                </div>

                                                @if (seleccionado)
                                                {
                                                    <span class="material-symbols-outlined ms-auto text-primary">check_circle</span>
                                                }
                                            </div>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <!-- Step 3 -->
                    <section class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold small"
                                      style="width: 32px; height: 32px;">3</span>
                                <h2 class="h5 fw-bold mb-0">Seleccionar fecha y hora</h2>
                            </div>

                            <div class="row g-4">
                                <!-- Calendar -->
                                <div class="col-12 col-md-6">
                                    <div class="border rounded-4 p-3">
                                        <div class="d-flex align-items-center justify-content-between mb-3">
                                            <span class="fw-bold text-capitalize">
                                                @MesActual.ToString("MMMM yyyy")
                                            </span>

                                            <div class="d-flex gap-2">
                                                <button type="button"
                                                        class="btn btn-sm btn-light rounded-circle p-1 d-inline-flex align-items-center justify-content-center"
                                                        @onclick="MesAnterior">
                                                    <span class="material-symbols-outlined">chevron_left</span>
                                                </button>

                                                <button type="button"
                                                        class="btn btn-sm btn-light rounded-circle p-1 d-inline-flex align-items-center justify-content-center"
                                                        @onclick="MesSiguiente">
                                                    <span class="material-symbols-outlined">chevron_right</span>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Week days -->
                                        <div class="row row-cols-7 g-1 text-center small text-secondary mb-2">
                                            <div class="col">L</div>
                                            <div class="col">M</div>
                                            <div class="col">X</div>
                                            <div class="col">J</div>
                                            <div class="col">V</div>
                                            <div class="col">S</div>
                                            <div class="col">D</div>
                                        </div>

                                        <!-- Days -->
                                        <div class="row row-cols-7 g-1 text-center">
                                            @foreach (var dia in DiasCalendario)
                                            {
                                                var esOtroMes = dia.Month != MesActual.Month;
                                                var esSeleccionado = FechaSeleccionada.HasValue && dia == FechaSeleccionada.Value;
                                                var deshabilitado = esOtroMes || !EsDiaHabilitado(dia) || dia < DateOnly.FromDateTime(DateTime.Today);

                                                <div class="col">
                                                    <button type="button"
                                                            class="btn btn-sm w-100 @(esSeleccionado ? "btn-primary fw-bold" : "btn-light") @(deshabilitado ? "text-secondary" : "")"
                                                            disabled="@deshabilitado"
                                                            @onclick="() => SeleccionarFecha(dia)">
                                                        @dia.Day
                                                    </button>
                                                </div>
                                            }
                                        </div>

                                        <div class="text-center small text-secondary fst-italic pt-3">
                                            Seleccioná una fecha habilitada para ver horarios
                                        </div>
                                    </div>
                                </div>

                                <!-- Slots -->
                                <div class="col-12 col-md-6">
                                    <p class="small fw-medium text-secondary mb-3">
                                        Franjas disponibles
                                        @if (FechaSeleccionada.HasValue)
                                        {
                                            <span>(@FechaSeleccionada.Value.ToString("dd/MM/yyyy"))</span>
                                        }
                                    </p>

                                    @if (!FechaSeleccionada.HasValue)
                                    {
                                        <div class="alert alert-light border mb-0">
                                            Elegí primero una fecha.
                                        </div>
                                    }
                                    else if (HorariosDisponibles.Count == 0)
                                    {
                                        <div class="alert alert-warning mb-0">
                                            No hay horarios disponibles para la fecha seleccionada.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="row row-cols-2 row-cols-sm-3 g-2">
                                            @foreach (var h in HorariosDisponibles)
                                            {
                                                var seleccionado = HoraSeleccionada == h;

                                                <div class="col">
                                                    <button type="button"
                                                            class="btn w-100 btn-sm @(seleccionado
                                                                                                                                                                                                                                                                                                                                                                            ? "border-2 border-primary text-primary bg-primary bg-opacity-10 fw-bold"
                                                                                                                                                                                                                                                                                                                                                                            : "btn-outline-secondary")"
                                                            @onclick="() => SeleccionarHorario(h)">
                                                        @h.ToString("HH:mm")
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <!-- Right column -->
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column gap-4 position-sticky" style="top: 96px;">
                    <!-- Step 4 -->
                    <section class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold small"
                                      style="width: 32px; height: 32px;">4</span>
                                <h2 class="h5 fw-bold mb-0">Detalles del Paciente</h2>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Error))
                            {
                                <div class="alert alert-danger py-2 mb-2">
                                    @Error
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Exito))
                            {
                                <div class="alert alert-success py-2 mb-2">
                                    @Exito
                                </div>
                            }

                            <form class="d-flex flex-column gap-3" @onsubmit="SubmitCreate" @onsubmit:preventDefault>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">Nombre</label>
                                        <input type="text" class="form-control" placeholder="Roberto..." @bind="Model.Nombre">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium">Apellido</label>
                                        <input type="text" class="form-control" placeholder="Fernandez..." @bind="Model.Apellido">
                                    </div>
                                </div>

                                <div>
                                    <label class="form-label fw-medium">Fecha de Nacimiento</label>
                                    <input type="date" class="form-control" @bind="Model.FechaNacimiento">
                                </div>

                                <div>
                                    <label class="form-label fw-medium">Correo Electronico</label>
                                    <input type="email" class="form-control" placeholder="email@example.com" @bind="Model.EmailPrincipal">
                                </div>

                                <div>
                                    <label class="form-label fw-medium">DNI (Numero de Identificación)</label>
                                    <input type="text" class="form-control" placeholder="12345678-X" @bind="Model.DNI">
                                </div>

                                <div class="d-flex justify-content-between gap-3 small mb-2">
                                    <span class="text-secondary">Médico</span>
                                    <span class="fw-medium text-dark text-end">
                                        @(Medicos.FirstOrDefault(x => x.Id == Model.MedicoId) is var med && med is not null
                                                                                ? $"{med.Nombre} {med.Apellido}"
                                                                                : "Sin seleccionar")
                                    </span>
                                </div>

                                <div class="d-flex justify-content-between gap-3 small mb-2">
                                    <span class="text-secondary">Consultorio</span>
                                    <span class="fw-medium text-dark text-end">
                                        @(Consultorios.FirstOrDefault(x => x.Id == Model.ConsultorioId) is var con && con is not null
                                                                                ? con.Institucion
                                                                                : "Sin seleccionar")
                                    </span>
                                </div>

                                <div class="d-flex justify-content-between gap-3 small mb-2">
                                    <span class="text-secondary">Fecha y hora</span>
                                    <span class="fw-medium text-dark text-end">
                                        @(
                                                                                FechaSeleccionada.HasValue && HoraSeleccionada.HasValue
                                                                                ? $"{FechaSeleccionada.Value:dd/MM/yyyy} {HoraSeleccionada.Value:HH\\:mm}"
                                                                                : "Sin seleccionar"
                                                                                )
                                    </span>
                                </div>
                            </form>
                        </div>

                        <button type="button"
                                @onclick="Create"
                                class="btn btn-primary w-100 py-3 fw-bold rounded-4 d-inline-flex align-items-center justify-content-center gap-2 shadow-sm"
                                disabled="@Guardando">
                            @if (Guardando)
                            {
                                <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <span>Confirmar cita</span>
                                <span class="material-symbols-outlined">arrow_forward</span>
                            }
                        </button>
                    </section>

                    <!-- Info -->
                    <div class="rounded-4 border p-3" style="background-color: #eef5ff; border-color: #dbeafe;">
                        <div class="d-flex align-items-start gap-2">
                            <span class="material-symbols-outlined text-primary">info</span>
                            <p class="small mb-0" style="color: #1e3a8a; line-height: 1.5;">
                                Recibirá un correo electrónico de confirmación una vez verificada su cita. Por favor, llegue 15 minutos antes.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@code {
    // =========================
    // Carga de médicos
    // =========================
    private List<ItemMedicos> Medicos = new();
    private bool CargandoMedicos;
    private string? ErrorMedicos;
    private string? Nombre;

    private record ItemMedicos(int Id, string Nombre, string Apellido, string Especialidad);

    private async Task CargarMedicos()
    {
        CargandoMedicos = true;
        ErrorMedicos = null;

        try
        {
            if (Model.ConsultorioId == 0)
            {
                Medicos = new();
                return;
            }

            var lista = await MedicosService.ListarPorConsultorioAsync(Model.ConsultorioId);

            Medicos = lista
                .Select(x => new ItemMedicos(x.Id, x.Nombre, x.Apellido, x.Especialidad))
                .OrderBy(x => x.Nombre)
                .ToList();
        }
        catch (Exception ex)
        {
            ErrorMedicos = ex.Message;
            Medicos = new();
        }
        finally
        {
            CargandoMedicos = false;
        }
    }

    private async Task SeleccionarMedico(int medicoId)
    {
        if (Model.ConsultorioId == 0)
        {
            Error = "Seleccioná primero un consultorio.";
            return;
        }

        Model.MedicoId = medicoId;
        HoraSeleccionada = null;
        Error = null;

        if (FechaSeleccionada.HasValue)
            await CargarHorariosDisponibles();
    }

    // =========================
    // Carga de consultorios
    // =========================
    private List<ItemConsultorios> Consultorios = new();
    private bool CargandoConsultorios;
    private string? ErrorConsultorios;

    private record ItemConsultorios(int Id, string Institucion, string Ciudad);

    private async Task CargarConsultorios()
    {
        CargandoConsultorios = true;
        ErrorConsultorios = null;

        try
        {
            var lista = await ConsultorioService.ListarAsync(Nombre);

            Consultorios = lista
                .Select(x => new ItemConsultorios(x.Id, x.Institucion, x.Ciudad))
                .OrderBy(x => x.Institucion)
                .ToList();
        }
        catch (Exception ex)
        {
            ErrorConsultorios = ex.Message;
            Consultorios = new();
        }
        finally
        {
            CargandoConsultorios = false;
        }
    }

    private async Task SeleccionarConsultorio(int consultorioId)
    {
        // Si cambia consultorio, resetear selección dependiente
        var cambioConsultorio = Model.ConsultorioId != consultorioId;

        Model.ConsultorioId = consultorioId;
        Error = null;

        if (cambioConsultorio)
        {
            Model.MedicoId = 0;
            HoraSeleccionada = null;
            HorariosDisponibles.Clear();
        }

        await CargarMedicos();

        // Si ya hay fecha elegida y (por algún motivo) ya quedó médico seleccionado, recargar horarios
        if (FechaSeleccionada.HasValue && Model.MedicoId != 0)
            await CargarHorariosDisponibles();
    }

    // =========================
    // Step 3 - Fecha y hora
    // =========================
    private DateTime MesActual = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateOnly? FechaSeleccionada;
    private TimeOnly? HoraSeleccionada;

    private List<DateOnly> DiasCalendario = new();
    private List<TimeOnly> HorariosDisponibles = new();

    private static readonly HashSet<DayOfWeek> DiasHabilitadosTurnos = new()
    {
        DayOfWeek.Monday,
        DayOfWeek.Tuesday,
        DayOfWeek.Wednesday,
        DayOfWeek.Thursday,
        DayOfWeek.Friday
    };

    // Config simple (fallback/mock visual si querés)
    private static readonly TimeOnly HoraInicioAgenda = new(9, 0);
    private static readonly TimeOnly HoraFinAgenda = new(18, 0);
    private const int DuracionTurnoMinutos = 30;

    // Descanso opcional
    private static readonly TimeOnly? DescansoDesdeAgenda = new(13, 0);
    private static readonly TimeOnly? DescansoHastaAgenda = new(14, 0);

    private void ConstruirCalendarioMes()
    {
        DiasCalendario.Clear();

        var primerDiaMes = new DateOnly(MesActual.Year, MesActual.Month, 1);

        int offset = primerDiaMes.DayOfWeek switch
        {
            DayOfWeek.Monday => 0,
            DayOfWeek.Tuesday => 1,
            DayOfWeek.Wednesday => 2,
            DayOfWeek.Thursday => 3,
            DayOfWeek.Friday => 4,
            DayOfWeek.Saturday => 5,
            DayOfWeek.Sunday => 6,
            _ => 0
        };

        var inicioGrilla = primerDiaMes.AddDays(-offset);

        for (int i = 0; i < 42; i++)
        {
            DiasCalendario.Add(inicioGrilla.AddDays(i));
        }
    }

    private bool EsDiaHabilitado(DateOnly fecha)
        => DiasHabilitadosTurnos.Contains(fecha.DayOfWeek);

    private async Task MesAnterior()
    {
        MesActual = MesActual.AddMonths(-1);
        ConstruirCalendarioMes();

        // Si la fecha seleccionada ya no está en el mes visible, no pasa nada.
        // Solo reconstruimos grilla.
        await Task.CompletedTask;
    }

    private async Task MesSiguiente()
    {
        MesActual = MesActual.AddMonths(1);
        ConstruirCalendarioMes();
        await Task.CompletedTask;
    }

    private async Task SeleccionarFecha(DateOnly fecha)
    {
        FechaSeleccionada = fecha;
        HoraSeleccionada = null;
        Error = null;

        // Si todavía no eligió médico o consultorio, mostrás mock (opcional)
        // para mantener la UI viva.
        if (Model.MedicoId == 0 || Model.ConsultorioId == 0)
        {
            CargarHorariosMock();
            return;
        }

        await CargarHorariosDisponibles();
    }

    // Mock opcional (fallback visual)
    private void CargarHorariosMock()
    {
        HorariosDisponibles.Clear();

        if (!FechaSeleccionada.HasValue)
            return;

        if (!EsDiaHabilitado(FechaSeleccionada.Value))
            return;

        var actual = HoraInicioAgenda;

        while (actual < HoraFinAgenda)
        {
            var enDescanso =
                DescansoDesdeAgenda.HasValue &&
                DescansoHastaAgenda.HasValue &&
                actual >= DescansoDesdeAgenda.Value &&
                actual < DescansoHastaAgenda.Value;

            if (!enDescanso)
            {
                HorariosDisponibles.Add(actual);
            }

            actual = actual.AddMinutes(DuracionTurnoMinutos);
        }

        // Demo visual de ocupados
        HorariosDisponibles.RemoveAll(h =>
            h == new TimeOnly(10, 0) ||
            h == new TimeOnly(14, 30));
    }

    private void SeleccionarHorario(TimeOnly hora)
    {
        HoraSeleccionada = hora;

        if (!FechaSeleccionada.HasValue)
            return;

        var fecha = FechaSeleccionada.Value;

        Model.FechaLocal = new DateTime(
            fecha.Year,
            fecha.Month,
            fecha.Day,
            hora.Hour,
            hora.Minute,
            0
        );
    }

    private async Task CargarHorariosDisponibles()
    {
        if (Model.MedicoId == 0 || Model.ConsultorioId == 0 || !FechaSeleccionada.HasValue)
        {
            HorariosDisponibles = new();
            return;
        }

        var fecha = FechaSeleccionada.Value;

        HorariosDisponibles = await TurnosService.ObtenerHorariosDisponiblesAsync(
            Model.MedicoId,
            Model.ConsultorioId,
            fecha);
    }

    // =========================
    // Crear turno
    // =========================
    private string? Error;
    private bool Guardando;
    private string? Exito;
    private CrearTurnoVm Model = new() { ConsultorioId = 0, MedicoId = 0 };

    private async Task Create()
    {
        Error = null;
        Exito = null;
        Guardando = true;

        try
        {
            if (Model.MedicoId == 0)
            {
                Error = "Seleccioná un médico.";
                return;
            }

            if (Model.ConsultorioId == 0)
            {
                Error = "Seleccioná un consultorio.";
                return;
            }

            if (!FechaSeleccionada.HasValue)
            {
                Error = "Seleccioná una fecha.";
                return;
            }

            if (!HoraSeleccionada.HasValue)
            {
                Error = "Seleccioná un horario.";
                return;
            }

            var req = new CrearTurnoConPacienteRequest
            {
                Nombre = Model.Nombre!,
                Apellido = Model.Apellido!,
                FechaNacimiento = Model.FechaNacimiento,
                EmailPrincipal = Model.EmailPrincipal!,
                DNI = Model.DNI!,
                MedicoId = Model.MedicoId,
                ConsultorioId = Model.ConsultorioId,
                FechaTurno = Model.FechaLocal
            };

            await TurnosService.CrearAsegurandoPacienteAsync(req);

            Exito = "Haz creado el turno exitosamente. Verifica la casilla de mensajes para verificar su turno";
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Guardando = false;
        }
    }

    private class CrearTurnoVm
    {
        public string? Nombre { get; set; }
        public string? Apellido { get; set; }
        public DateTime FechaNacimiento { get; set; } // si tu DTO acepta nullable, podés poner DateTime?
        public string? EmailPrincipal { get; set; }
        public string? DNI { get; set; }

        public int MedicoId { get; set; }
        public int ConsultorioId { get; set; }

        public DateTime FechaLocal { get; set; } = DateTime.Now;
    }

