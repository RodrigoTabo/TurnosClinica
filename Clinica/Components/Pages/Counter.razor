    protected override async Task OnInitializedAsync()
    {
        ConstruirCalendarioMes();

        await CargarConsultorios();
        await CargarMedicos();

        // Opcional: seleccionar hoy automáticamente si está habilitado
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        if (EsDiaHabilitado(hoy))
        {
            FechaSeleccionada = hoy;

            // Como al inicio no hay médico/consultorio elegidos, usamos mock para UX visual.
            CargarHorariosMock();
        }
    }

