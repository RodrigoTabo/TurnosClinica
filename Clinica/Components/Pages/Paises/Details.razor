@page "/paises/details/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using TurnosClinica.Application.DTOs.Paises
@using TurnosClinica.Application.Services.Paises
@inject IPaisesService PaisesService
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav




<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">

    <MudStack Spacing="1">
        <MudText Typo="Typo.h4">Países</MudText>
        <MudText Typo="Typo.subtitle2" Color="Color.Default">Administración</MudText>
    </MudStack>

    <MudPaper Class="mt-4" Outlined="true" Elevation="0">

        <MudToolBar Dense="true" Class="px-4 py-3">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">País #@Id</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Ver y editar país</MudText>
            </MudStack>

            <MudSpacer />

            <MudButton ButtonType="ButtonType.Button"
                       Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="Volver"
                       Disabled="@Guardando"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Volver
            </MudButton>
        </MudToolBar>

        <MudDivider />

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mx-4 mt-4">
                @Error
            </MudAlert>
        }

        <div class="px-4 py-4">
            @if (Cargando)
            {
                <MudStack Class="py-8" AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                    <MudText Color="Color.Default">Cargando...</MudText>
                </MudStack>
            }
            else if (Pais is null)
            {
                <MudStack Class="py-8" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.h6">El país no existe</MudText>
                    <MudText Color="Color.Default">Puede haber sido eliminado o el ID es inválido.</MudText>
                </MudStack>
            }
            else
            {
                <MudGrid Spacing="2">

                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Default">ID</MudText>

                        <MudPaper Outlined="true" Class="px-3 py-1 mt-1" Style="display:inline-block;">
                            <MudText Typo="Typo.body2"><b>#@Pais.Id</b></MudText>
                        </MudPaper>
                    </MudItem>

  
                    <MudItem xs="12" md="9">
                        <MudText Typo="Typo.caption" Color="Color.Default">Nombre</MudText>

                        @if (!Editando)
                        {
                            <MudText Typo="Typo.body1" Class="mt-1">@Pais.Nombre</MudText>
                        }
                        else
                        {
                            <MudTextField @bind-Value="Model.Nombre"
                                          Placeholder="Nombre del país"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          Disabled="@Guardando"
                                          FullWidth="true"
                                          Class="mt-1" />
                        }
                    </MudItem>
                </MudGrid>
            }
        </div>


        @if (Pais is not null && !Cargando)
        {
            <MudDivider />

            <MudStack Row="true"
                      Spacing="2"
                      Justify="Justify.FlexEnd"
                      AlignItems="AlignItems.Center"
                      Class="px-4 py-3">

                @if (!Editando)
                {
                    <MudButton ButtonType="ButtonType.Button"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Disabled="@Guardando"
                               OnClick="EntrarEdicion">
                        Editar
                    </MudButton>
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Button"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               Disabled="@Guardando"
                               OnClick="Guardar">
                        @(Guardando ? "Guardando..." : "Guardar")
                    </MudButton>

                    <MudButton ButtonType="ButtonType.Button"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               Disabled="@Guardando"
                               OnClick="Cancelar">
                        Cancelar
                    </MudButton>
                }
            </MudStack>
        }

    </MudPaper>

</MudContainer>

@code {
    [Parameter] public int Id { get; set; }

    private bool Cargando = true;
    private bool Editando = false;
    private bool Guardando = false;
    private string? Error;

    private PaisResponse? Pais;
    private UpdatePaisRequest Model = new();

    protected override async Task OnParametersSetAsync() => await Cargar();

    private async Task Cargar()
    {
        Cargando = true;
        Error = null;

        try
        {
            Pais = await PaisesService.GetByIdAsync(Id);
            if (Pais is not null)
                Model.Nombre = Pais.Nombre;
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            Pais = null;
        }
        finally
        {
            Cargando = false;
        }
    }

    private void EntrarEdicion()
    {
        if (Pais is null) return;
        Editando = true;
        Model.Nombre = Pais.Nombre;
    }

    private async Task Guardar()
    {
        if (Pais is null) return;

        Guardando = true;
        Error = null;

        try
        {
            // guardamos tal cual esté (trim) y el server valida
            Model.Nombre = (Model.Nombre ?? "").Trim();

            await PaisesService.UpdateAsync(Id, Model);

            Pais = await PaisesService.GetByIdAsync(Id);
            if (Pais is not null)
                Model.Nombre = Pais.Nombre;

            Editando = false;
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Guardando = false;
        }
    }

    private void Cancelar()
    {
        Editando = false;
        if (Pais is not null)
            Model.Nombre = Pais.Nombre;
    }

    private void Volver() => Nav.NavigateTo("/paises");
}
