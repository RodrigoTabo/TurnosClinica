@page "/paises"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using TurnosClinica.Application.DTOs.Paises
@using TurnosClinica.Application.Services.Paises
@inject IPaisesService PaisesService
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.JSInterop
@inject IJSRuntime JsRuntime



<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">

    <MudStack Spacing="1">
        <MudText Typo="Typo.h4">Países</MudText>
        <MudText Typo="Typo.subtitle2" Color="Color.Default">Administración</MudText>
    </MudStack>

    <MudPaper Class="mt-4" Outlined="true" Elevation="0">

        <MudToolBar Dense="true" Class="px-4 py-3">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">Lista de países</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Gestioná el País</MudText>
            </MudStack>

            <MudSpacer />

            <MudButton Href="/paises/crear"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add">
                Crear nuevo
            </MudButton>
        </MudToolBar>

        <MudDivider />

        <!-- Filtro -->
        <MudStack Class="px-4 py-4" Spacing="2">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="Nombre"
                                  Label="Nombre"
                                  Placeholder="Ej: Argentina..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Clearable="true"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                        <MudButton ButtonType="ButtonType.Button"
                                   OnClick="Cargar"
                                   Disabled="Cargando"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Search">
                            Buscar
                        </MudButton>

                        <MudButton ButtonType="ButtonType.Button"
                                   OnClick="Limpiar"
                                   Disabled="Cargando"
                                   Variant="Variant.Text"
                                   Color="Color.Default">
                            Limpiar
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    @Error
                </MudAlert>
            }
        </MudStack>

        <MudDivider />

        @if (Cargando)
        {
            <MudStack Class="py-8" AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                <MudText Color="Color.Secondary">Cargando...</MudText>
            </MudStack>
        }
        else
        {
            <MudTable Items="Paises"
                      Hover="true"
                      Striped="true"
                      Dense="true"
                      Breakpoint="Breakpoint.Sm"
                      FixedHeader="true"
                      Height="420px"
                      Elevation="0">

                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Nombre</MudTh>
                    <MudTh Align="Align.Right">Acciones</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd><b>#@context.Id</b></MudTd>
                    <MudTd>@context.Nombre</MudTd>
                    <MudTd Align="Align.Right">
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Color="Color.Primary"
                                           Variant="Variant.Text"
                                           Size="Size.Small"
                                           Href="@($"/paises/details/{context.Id}")" />

                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Variant="Variant.Text"
                                           Size="Size.Small"
                                           OnClick="@(() => Eliminar(context.Id))" />
                        </MudStack>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <MudText Color="Color.Default" Align="Align.Center" Class="py-6">
                        No hay países para mostrar.
                    </MudText>
                </NoRecordsContent>
            </MudTable>
        }

        <MudDivider />

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="px-4 py-3">
            <MudText Color="Color.Default">Total</MudText>

            <MudBadge Content="@Paises.Count" Color="Color.Primary" Overlap="true">
            </MudBadge>
        </MudStack>

    </MudPaper>

</MudContainer>



@code {
    private List<PaisResponse> Paises = new();
    private bool Cargando;
    private string? Error;
    private string? Nombre;


    private async Task Limpiar()
    {
        Nombre = null;
        await Cargar();
    }

    private async Task Cargar()
    {
        Cargando = true;
        Error = null;

        try
        {
            Paises = await PaisesService.ListarAsync(Nombre);
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Cargando = false;
        }

    }

    private async Task Eliminar(int id)
    {
        if (!await JsRuntime.InvokeAsync<bool>("confirm", $"¿Confirma que desea eliminar el país #{id}?"))
            return;
        Error = null;
        try
        {
            await PaisesService.SoftDeleteAsync(id);
            await Cargar();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
    }

    //Inicializa la carga siempre.
    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

}