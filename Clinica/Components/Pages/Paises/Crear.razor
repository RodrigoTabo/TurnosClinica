@page "/paises/crear"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using TurnosClinica.Application.DTOs.Paises
@using TurnosClinica.Application.Services.Paises
@inject IPaisesService PaisesService
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">

    <MudStack Spacing="1">
        <MudText Typo="Typo.h4">Países</MudText>
        <MudText Typo="Typo.subtitle2" Color="Color.Default">Administración</MudText>
    </MudStack>

    <MudPaper Class="mt-4" Outlined="true" Elevation="0">

        <!-- Toolbar -->
        <MudToolBar Dense="true" Class="px-4 py-3">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">Nuevo país</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">Completá los datos y guardá</MudText>
            </MudStack>

            <MudSpacer />

            <MudButton ButtonType="ButtonType.Button"
                       Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="Volver"
                       Disabled="@Guardando"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Volver
            </MudButton>
        </MudToolBar>

        <MudDivider />

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mx-4 mt-4">
                @Error
            </MudAlert>
        }

        <MudStack Class="px-4 py-4" Spacing="2">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="Model.Nombre"
                                  Label="Nombre"
                                  Placeholder="Ej: Argentina..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Public"
                                  Clearable="true"
                                  Disabled="@Guardando"
                                  FullWidth="true" />

                    <MudText Typo="Typo.caption" Color="Color.Default">
                        Debe ser único. Se recortan espacios al guardar.
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudStack>

        <MudDivider />

        <MudStack Row="true"
                  Justify="Justify.FlexEnd"
                  AlignItems="AlignItems.Center"
                  Spacing="2"
                  Class="px-4 py-3">

            <MudButton ButtonType="ButtonType.Button"
                       Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="Volver"
                       Disabled="@Guardando">
                Cancelar
            </MudButton>

            <MudButton ButtonType="ButtonType.Button"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Create"
                       Disabled="@Guardando"
                       StartIcon="@Icons.Material.Filled.CheckCircle">
                @(Guardando ? "Guardando..." : "Crear")
            </MudButton>

        </MudStack>

    </MudPaper>
</MudContainer>

@code {
    private string? Error;
    private bool Guardando;

    private CrearPaisVM Model = new();

    private async Task Create()
    {
        Error = null;
        Guardando = true;

        try
        {
            var nombre = (Model.Nombre ?? "").Trim();
            var req = new CrearPaisRequest { Nombre = nombre };

            var id = await PaisesService.CrearAsync(req);
            Nav.NavigateTo($"/paises/details/{id}");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Guardando = false;
        }
    }

    private async Task FooterClick()
    {
        // Backup si el botón no recibe click (overlay)
        if (Guardando) return;
        await Create();
    }

    private void Volver() => Nav.NavigateTo("/paises");

    private class CrearPaisVM
    {
        public string Nombre { get; set; } = "";
    }
}
